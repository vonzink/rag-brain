# ============================================================
# MSFG RAG — environment configuration
# Copy to .env for local dev. In production these come from
# AWS Secrets Manager / environment, never from a file.
# ============================================================

# --- Database (matches docker-compose.yml) ---
DB_URL=jdbc:postgresql://localhost:5433/msfg_rag
DB_USERNAME=msfg_rag
DB_PASSWORD=local_dev_only

# --- AI providers ---
# Claude writes the answers; OpenAI generates the embeddings
# (Anthropic does not offer an embeddings API).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Model routing ---
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_AI_MODEL=claude-haiku-4-5
FALLBACK_AI_PROVIDER=openai
FALLBACK_AI_MODEL=gpt-4.1-nano

# --- Embeddings ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- Retrieval tuning ---
RETRIEVAL_TOP_K=8
RETRIEVAL_CONFIDENCE_THRESHOLD=0.35

# --- Website CORS (comma-separated origins allowed to call the public API) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Admin API protection (replace with Cognito at deployment) ---
ADMIN_API_KEY=change-me-local-admin-key

# --- Document storage (local for MVP; S3 in production) ---
DOCUMENT_STORAGE_PATH=./data/documents

# --- Domain pack (brain identity) ---
# BRAIN_PACK is relative to the process working directory; use an absolute path
# in deployed environments.
BRAIN_PACK=packs/msfg-mortgage
BRAIN_SLUG=mortgage

# --- Optional extra AI providers (leave blank = provider hidden) ---
# Add a key and restart the brain; the provider then appears in the dashboard.
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
GROK_API_KEY=
# GROK_MODEL=grok-4.3
