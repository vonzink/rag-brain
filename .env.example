# ============================================================
# rag-brain environment configuration
# Copy to .env for local dev. In production, provide these from
# environment variables or a secrets manager.
# ============================================================

# --- Database (matches docker-compose.yml) ---
DB_URL=jdbc:postgresql://localhost:5435/rag_brain
DB_USERNAME=rag_brain
DB_PASSWORD=local_dev_only

# --- AI providers ---
# AI keys may be blank for dashboard/admin boot.
# OPENAI_API_KEY is required for text-embedding-3-small ingestion/retrieval.
# At least one answer provider or LOCAL_LLM_BASE_URL is required for generated answers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- AI HTTP timeouts (outbound provider/embedding calls) ---
# Guard against hung providers. read timeout must exceed normal completion latency.
AI_CONNECT_TIMEOUT_MS=10000
AI_READ_TIMEOUT_MS=60000
# Max source-context tokens packed into a prompt (cl100k_base). Prevents context-window overflow.
AI_MAX_CONTEXT_TOKENS=12000

# --- Model routing ---
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_AI_MODEL=claude-haiku-4-5
FALLBACK_AI_PROVIDER=openai
FALLBACK_AI_MODEL=gpt-4.1-nano

# --- Embeddings ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- Retrieval tuning ---
RETRIEVAL_TOP_K=8
RETRIEVAL_CONFIDENCE_THRESHOLD=0.35
RETRIEVAL_RERANK_ENABLED=true

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# --- Rate limiting (public ask endpoint) ---
# X-Forwarded-For is spoofable, so it is ignored unless the app is strictly
# behind a trusted proxy. Enable only when ALL traffic flows through your proxy,
# and set the count to the number of proxies appending to the header.
RATE_LIMIT_TRUST_FORWARDED_FOR=false
RATE_LIMIT_TRUSTED_PROXY_COUNT=1

# --- Admin API protection ---
ADMIN_API_KEY=change-me-local-admin-key

# Public website assistant tokens are generated per brain from the dashboard/API.
# They are stored hashed in PostgreSQL and are separate from ADMIN_API_KEY.
# Do not add a static public token env var here as an app setting.

# --- Default brain and local corpus ---
# Keep the platform default generic and empty. Use packs/msfg-mortgage only for examples/tests.
DOCUMENT_STORAGE_PATH=./data/generic-documents
BRAIN_PACK=packs/generic
BRAIN_SLUG=generic
BRAIN_NAME="Generic Brain"

# --- Dashboard ---
# The Test Console's full ask mode calls /api/ai/<slug>/ask?brain=<active-brain>.
# Keep this generic for new deployments; set to an existing route slug only for legacy sites.
VITE_LEGACY_ASK_SLUG=generic

# --- Optional S3 corpus source for the default brain ---
S3_BUCKET=
S3_PREFIX=
AWS_REGION=us-west-1

# --- Optional extra AI providers (blank = hidden/unconfigured) ---
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
GROK_API_KEY=
# GROK_MODEL=grok-4.3

# --- Local/self-hosted OpenAI-compatible LLM ---
# Example: http://127.0.0.1:11434/v1 for Ollama's OpenAI-compatible server.
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=

# Comma-separated host allowlist for per-brain local endpoints.
# Empty uses LocalEndpointValidator defaults.
LOCAL_LLM_ALLOWED_HOSTS=
